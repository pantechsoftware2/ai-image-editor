# Environment Variables Template
# Copy to .env.local and fill in your actual values
# NEVER commit .env.local to version control

# Supabase Configuration
# Get these from https://supabase.com project settings
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url_here
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_KEY=your_supabase_service_key_here

# Google Cloud - Vertex AI Configuration
# Get these from Google Cloud Console
NEXT_PUBLIC_GOOGLE_CLOUD_PROJECT_ID=your_project_id_here
NEXT_PUBLIC_GOOGLE_CLOUD_REGION=us-central1
GOOGLE_CLOUD_CLIENT_EMAIL=your_service_account_email_here
GOOGLE_CLOUD_PRIVATE_KEY=your_private_key_here_with_newlines_escaped

# Application Settings
NEXT_PUBLIC_API_URL=http://localhost:3000
NODE_ENV=development
